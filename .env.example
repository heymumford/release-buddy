# --- GitHub App (required) ---
# The ID of your GitHub App
APP_ID=
# GitHub App webhook secret
WEBHOOK_SECRET=
# GitHub App private key (PEM contents, or place a .pem file next to the app)
PRIVATE_KEY=
# Local dev only: your smee.io proxy URL (https://smee.io/new)
WEBHOOK_PROXY_URL=
# `trace` for verbose logging, `info` for less
LOG_LEVEL=info

# --- Slack notifier (optional) ---
# Set this when a repo's releaseBuddy.config.json uses
# "slackWebhookUrlEnv": "SLACK_WEBHOOK_URL" (recommended over committing the URL).
# The env var name is whatever the config points at; this is the common default.
SLACK_WEBHOOK_URL=

# --- Email notifier (optional) ---
# SendGrid API key
SENDGRID_API_KEY=

# --- Confluence notifier (optional) ---
# Atlassian account email
CONFLUENCE_USER=
# Atlassian API token (https://id.atlassian.com/manage-profile/security/api-tokens)
CONFLUENCE_API_KEY=
# Confluence base URL, including /wiki for Cloud, e.g. https://your-org.atlassian.net/wiki
CONFLUENCE_BASE_URL=
