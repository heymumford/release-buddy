{
	"name": "release-buddy",
	"version": "2.2.0",
	"private": true,
	"type": "module",
	"description": "GitHub App that fans out release notes to Slack, email, and Confluence when you publish a release.",
	"author": "Cam Sloan <cam@sloan.ca> (original), heymumford (modernization)",
	"license": "ISC",
	"repository": "github:heymumford/release-buddy",
	"homepage": "https://github.com/heymumford/release-buddy",
	"bugs": "https://github.com/heymumford/release-buddy/issues",
	"keywords": [
		"probot",
		"github",
		"probot-app",
		"release",
		"slack",
		"confluence",
		"notifications"
	],
	"main": "index.js",
	"bin": {
		"release-buddy": "bin/release.js"
	},
	"scripts": {
		"start": "probot run ./index.js",
		"dev": "nodemon --exec \"probot run ./index.js\"",
		"release": "node bin/release.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "prettier --check . && markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
		"lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@sendgrid/mail": "^8.1.6",
		"marked": "^18.0.5",
		"probot": "^14.3.2",
		"remove-markdown": "^0.6.4",
		"slackify-markdown": "^5.0.0"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^4.0.16",
		"markdownlint-cli2": "^0.23.0",
		"nodemon": "^3.1.9",
		"prettier": "^3.9.4",
		"smee-client": "^5.0.0",
		"vitest": "^4.0.16"
	},
	"engines": {
		"node": ">=20"
	}
}
